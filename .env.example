# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/rhine_alps_express"

# ─────────────────────────────────────────
# AUTH.JS (NextAuth v5)
# ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Full URL of the app (include port in dev)
AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────
# M-PESA (Safaricom Daraja API)
# ─────────────────────────────────────────
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
# "sandbox" or "production"
MPESA_ENVIRONMENT="sandbox"

# ─────────────────────────────────────────
# MAPS (Google Maps Platform)
# ─────────────────────────────────────────
GOOGLE_MAPS_API_KEY=""

# ─────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────
# SMS / WhatsApp provider (e.g. Africa's Talking, Twilio)
SMS_PROVIDER_API_KEY=""
SMS_PROVIDER_SENDER_ID="RhineAlps"

# ─────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Rhine Alps Express"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
