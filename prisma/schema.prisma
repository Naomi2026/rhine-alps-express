// prisma/schema.prisma
// Rhine Alps Express — complete data model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════

enum UserRole {
  CUSTOMER
  RIDER
  ADMIN
  SUPER_ADMIN
}

/// Full order lifecycle per business-rules.md §12
enum OrderStatus {
  PLACED
  AWAITING_PAYMENT
  CONFIRMED
  PREPARING
  READY_FOR_DISPATCH
  ASSIGNED_TO_RIDER
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  FAILED_DELIVERY
  CANCELLED
  ON_HOLD
}

/// Logistics-side progress tracked separately from order status (§27)
enum DeliveryStatus {
  NOT_SCHEDULED
  SCHEDULED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  ARRIVED
  PENDING_OTP_CONFIRMATION
  DELIVERED
  DELIVERY_ATTEMPTED
  FAILED
  RETURNED
}

/// Financial settlement state tracked separately from order (§14)
enum PaymentStatus {
  UNPAID
  PENDING_VERIFICATION
  PARTIALLY_PAID
  PAID
  FAILED
  CREDIT_APPLIED
}

enum PaymentMethod {
  MPESA
  CASH_ON_DELIVERY
}

/// Distance-based pricing bands (§7)
enum PricingBand {
  BAND_1 // 0–2 km, KES 150/bottle, no delivery fee
  BAND_2 // predefined areas, KES 200/bottle, no delivery fee
  BAND_3 // all else ≤30 km, KES 150/bottle + KES 30/km delivery fee
}

enum NotificationChannel {
  SMS
  WHATSAPP
  EMAIL
  IN_APP
}

/// Controlled reason for credit ledger entries (§10)
enum CreditReason {
  CANCELLED_ORDER
  OVERPAYMENT
  CHANGE_OWED
  MANUAL_ADJUSTMENT
  CREDIT_USED
}

// ═══════════════════════════════════════════════════════
// AUTH.JS REQUIRED MODELS
// Extended with domain fields — adapter ignores extras.
// ═══════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String
  email         String?   @unique
  phone         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  isLocked      Boolean   @default(false)
  failedLogins  Int       @default(0)
  createdById   String?   // set when Super Admin creates an admin/rider account
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  customer      Customer?
  rider         Rider?
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([role])
  @@index([isActive])
  @@index([phone])
}

/// Required by @auth/prisma-adapter (OAuth future-proofing)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// Required by @auth/prisma-adapter (unused with JWT strategy; included for forward compat)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Required by @auth/prisma-adapter
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════════
// CUSTOMER PROFILE
// ═══════════════════════════════════════════════════════

model Customer {
  id                 String   @id @default(cuid())
  userId             String   @unique
  /// Single saved address per MVP (§4.2)
  defaultAddress     String?
  defaultLat         Float?
  defaultLng         Float?
  defaultLocationRef String?
  /// Running total; always computed via CreditTransaction ledger
  creditBalance      Decimal  @default(0) @db.Decimal(10, 2)
  /// Count of completed qualifying orders toward loyalty reward (§11)
  loyaltyCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders             Order[]
  creditTransactions CreditTransaction[]

  @@index([creditBalance])
}

// ═══════════════════════════════════════════════════════
// RIDER PROFILE
// ═══════════════════════════════════════════════════════

model Rider {
  id        String   @id @default(cuid())
  userId    String   @unique
  isOnline  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries Delivery[]
}

// ═══════════════════════════════════════════════════════
// DELIVERY SLOTS  (§3)
// ═══════════════════════════════════════════════════════

model DeliverySlot {
  id        String   @id @default(cuid())
  label     String   // "9:00 AM – 12:00 PM"
  startTime String   // "09:00" (24-hr)
  endTime   String   // "12:00" (24-hr)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  capacities SlotCapacity[]
}

/// Capacity per pricing band (zone proxy) per slot per date (§3.4)
model SlotCapacity {
  id           String      @id @default(cuid())
  slotId       String
  pricingBand  PricingBand
  date         DateTime    @db.Date
  maxOrders    Int         @default(20)
  /// Includes unpaid orders during the 4-hour reservation window (§3.5)
  bookedOrders Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  slot DeliverySlot @relation(fields: [slotId], references: [id])

  @@unique([slotId, pricingBand, date])
  @@index([date])
}

// ═══════════════════════════════════════════════════════
// SERVICE ZONES  (Band 2 area registry)
// ═══════════════════════════════════════════════════════

/// Admin-manageable registry of Band 2 named areas (§7.2)
model ServiceZone {
  id          String      @id @default(cuid())
  name        String      @unique
  /// Alternate spellings / known aliases for fuzzy matching
  aliases     String[]
  pricingBand PricingBand @default(BAND_2)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ═══════════════════════════════════════════════════════
// ORDERS  (§8, §9, §12)
// ═══════════════════════════════════════════════════════

model Order {
  id          String        @id @default(cuid())
  /// Human-readable reference, e.g. "RAX-20240415-001"
  orderRef    String        @unique
  customerId  String
  status      OrderStatus   @default(PLACED)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod

  // ── Delivery location ───────────────────────────────
  deliveryAddress    String
  deliveryLat        Float?
  deliveryLng        Float?
  locationRef        String?
  isLocationValid    Boolean @default(true)
  /// True when location is ambiguous and price is provisional (§5.8, §7.8)
  isProvisionalPrice Boolean @default(false)

  // ── Slot assignment ─────────────────────────────────
  slotId       String?
  deliveryDate DateTime? @db.Date

  // ── Pricing (stored denormalised for reporting) ─────
  pricingBand     PricingBand
  distanceKm      Float?
  bottleUnitPrice Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @default(0) @db.Decimal(10, 2)
  /// bottleUnitPrice × total quantity
  subtotal        Decimal     @db.Decimal(10, 2)
  /// subtotal + deliveryFee
  totalAmount     Decimal     @db.Decimal(10, 2)
  /// Credit auto-applied from Customer.creditBalance (§10.3)
  creditApplied   Decimal     @default(0) @db.Decimal(10, 2)
  /// totalAmount − creditApplied
  amountDue       Decimal     @db.Decimal(10, 2)

  // ── Loyalty ─────────────────────────────────────────
  /// True when this order IS the free bottle loyalty reward
  isLoyaltyReward  Boolean @default(false)
  /// False for cancelled/failed/invalid orders (§11.1)
  countsForLoyalty Boolean @default(true)

  // ── State flags ─────────────────────────────────────
  isAdminConfirmed   Boolean @default(false)
  hasBeenRescheduled Boolean @default(false)

  // ── Notes and controlled reasons ────────────────────
  deliveryNotes      String?
  cancellationReason String? // maps to CancelledReason constants
  cancellationNote   String?
  onHoldReason       String? // maps to OnHoldReason constants
  onHoldNote         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer  Customer      @relation(fields: [customerId], references: [id])
  slot      DeliverySlot? @relation(fields: [slotId], references: [id])
  items     OrderItem[]
  delivery  Delivery?
  payments  Payment[]
  otp       OTPRecord?
  auditLogs AuditLog[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([deliveryDate])
  @@index([pricingBand])
  @@index([createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productName String  // "20L Bottle – New" | "20L Bottle – Refill"
  productSku  String  // "20L-NEW" | "20L-REFILL"
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  lineTotal   Decimal @db.Decimal(10, 2)
  /// True when customer provides empty bottle for exchange (§6.5)
  isExchange  Boolean @default(false)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ═══════════════════════════════════════════════════════
// DELIVERY  (§13, §18)
// ═══════════════════════════════════════════════════════

model Delivery {
  id      String         @id @default(cuid())
  orderId String         @unique
  riderId String?
  status  DeliveryStatus @default(NOT_SCHEDULED)

  // ── GPS timestamps ──────────────────────────────────
  pickedUpAt  DateTime?
  arrivedAt   DateTime?
  deliveredAt DateTime?
  arrivalLat  Float?
  arrivalLng  Float?
  deliveryLat Float?
  deliveryLng Float?

  // ── Recipient ───────────────────────────────────────
  /// Populated when delivery accepted by someone other than the customer (§21.9)
  recipientName String?

  // ── Cash collection ─────────────────────────────────
  cashCollected Decimal? @db.Decimal(10, 2)

  // ── Failure / return (§21) ──────────────────────────
  failedReason String? // maps to FailedDeliveryReason constants
  failedNote   String?
  returnedQty  Int?
  returnReason String? // maps to ReturnedReason constants

  // ── Proof of delivery ───────────────────────────────
  proofPhotoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order    Order             @relation(fields: [orderId], references: [id])
  rider    Rider?            @relation(fields: [riderId], references: [id])
  attempts DeliveryAttempt[]

  @@index([riderId])
  @@index([status])
}

model DeliveryAttempt {
  id          String   @id @default(cuid())
  deliveryId  String
  attemptedAt DateTime @default(now())
  result      String   // "attempted" | "failed" | "successful"
  reason      String?
  note        String?
  riderId     String?

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
}

// ═══════════════════════════════════════════════════════
// PAYMENTS  (§9)
// ═══════════════════════════════════════════════════════

model Payment {
  id      String        @id @default(cuid())
  orderId String
  method  PaymentMethod
  amount  Decimal       @db.Decimal(10, 2)
  status  PaymentStatus

  // ── M-Pesa fields ───────────────────────────────────
  /// Unique constraint enforces no-duplicate-code rule (§9.7)
  mpesaCode       String?  @unique
  mpesaPhone      String?
  enteredByUserId String?
  enteredAt       DateTime?

  // ── COD fields ──────────────────────────────────────
  cashReceivedAmount Decimal? @db.Decimal(10, 2)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════
// OTP  (§15)
// ═══════════════════════════════════════════════════════

model OTPRecord {
  id      String @id @default(cuid())
  orderId String @unique

  /// bcrypt hash — OTP value is NEVER stored as plain text (§24.5)
  tokenHash          String
  expiresAt          DateTime
  isUsed             Boolean   @default(false)
  usedAt             DateTime?
  /// Max 3 per business rules (§15.3)
  validationAttempts Int       @default(0)
  /// Max 3 resends; 30 s cooldown enforced in application layer (§15.3)
  resendAttempts     Int       @default(0)
  lastResendAt       DateTime?
  createdAt          DateTime  @default(now())

  order         Order             @relation(fields: [orderId], references: [id])
  verifications OTPVerification[]
}

/// Audit trail for every OTP validation attempt (§15.4)
model OTPVerification {
  id          String   @id @default(cuid())
  otpId       String
  result      String   // "success" | "failure"
  submittedBy String   // userId of rider or admin
  submittedAt DateTime @default(now())
  note        String?

  otp OTPRecord @relation(fields: [otpId], references: [id], onDelete: Cascade)

  @@index([otpId])
}

// ═══════════════════════════════════════════════════════
// CUSTOMER CREDIT  (§10)
// ═══════════════════════════════════════════════════════

/// Immutable ledger — credit is never deleted, only reversed via new entries
model CreditTransaction {
  id              String       @id @default(cuid())
  customerId      String
  /// Positive = credit added; negative = credit consumed
  amount          Decimal      @db.Decimal(10, 2)
  reason          CreditReason
  relatedOrderId  String?
  createdByUserId String?
  note            String?
  createdAt       DateTime     @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════
// AUDIT LOG  (§17.4, §24)
// ═══════════════════════════════════════════════════════

/// Append-only — no UPDATE or DELETE permitted on this table (enforced in app layer)
model AuditLog {
  id         String   @id @default(cuid())
  /// Dot-notated action, e.g. "order.status.changed", "payment.code.entered", "otp.override"
  action     String
  entityType String   // "Order" | "Payment" | "User" | "Delivery" | "OTPRecord" | …
  entityId   String
  userId     String?  // null for system-triggered events
  orderId    String?  // denormalised for fast order-centric queries
  before     Json?    // previous state snapshot
  after      Json?    // new state snapshot
  reason     String?  // controlled reason code
  note       String?  // free-text note from acting user
  ipAddress  String?
  createdAt  DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@index([entityType, entityId])
  @@index([orderId])
  @@index([userId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════
// NOTIFICATIONS  (§20)
// ═══════════════════════════════════════════════════════

model Notification {
  id         String              @id @default(cuid())
  userId     String
  channel    NotificationChannel
  /// e.g. "order.placed", "payment.confirmed", "otp.sent", "delivery.failed"
  event      String
  subject    String?
  body       String              @db.Text
  isSent     Boolean             @default(false)
  sentAt     DateTime?
  failedAt   DateTime?
  failReason String?
  retryCount Int                 @default(0)
  createdAt  DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isSent])
  @@index([event])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════
// SYSTEM SETTINGS
// ═══════════════════════════════════════════════════════

/// Key-value store for admin-configurable business parameters
model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedById String?
}
