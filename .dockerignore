# .dockerignore
# Keeps the Docker build context small and prevents secrets leaking into the image.

node_modules
.next
.git
.gitignore

# Environment files — injected at runtime via env_file or -e flags
.env
.env.local
.env.*.local

# Dev tooling
*.log
.DS_Store
coverage
tsconfig.tsbuildinfo

# Docs that are not needed in the image
README.md
docs/
